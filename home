:root{
  --navy:#0B2545;
  --gold:#D4AF37;
  --muted:#6b7280;
  --bg:#ffffff;
}
*{box-sizing:border-box}
body{font-family:Inter, Arial, sans-serif; margin:0; color:var(--navy); background:var(--bg); line-height:1.6}
.container{max-width:1000px; margin:0 auto; padding:2rem}
.site-header{position:sticky; top:0; background:rgba(255,255,255,0.95); border-bottom:1px solid #eee; z-index:50}
.header-inner{display:flex; align-items:center; justify-content:space-between}
.brand{display:flex; align-items:center; gap:1rem}
.logo-placeholder{background:var(--navy); color:#fff; font-weight:700; padding:10px 14px; border-radius:6px}
.company-name{font-weight:700; font-size:18px}
.tagline{font-size:12px; color:var(--muted)}
.nav a{margin-left:14px; text-decoration:none; color:var(--navy); font-size:14px}
.btn-primary{background:var(--navy); color:#fff; padding:10px 14px; border-radius:6px; text-decoration:none; margin-left:8px}
.btn-secondary{border:1px solid var(--navy); color:var(--navy); padding:10px 14px; border-radius:6px; text-decoration:none}
.hero{padding:6rem 0; background:linear-gradient(180deg, rgba(11,37,69,0.03), rgba(11,37,69,0.00)); display:flex; align-items:center}
.hero h1{font-size:28px; margin-bottom:0.5rem}
.hero p{color:var(--muted); max-width:760px}
.section{padding:3.5rem 0}
.cards{display:grid; grid-template-columns:repeat(auto-fit, minmax(220px,1fr)); gap:16px; margin-top:1rem}
.card{border:1px solid #eee; padding:16px; border-radius:8px; background:#fff}
.site-footer{padding:2rem 0; border-top:1px solid #f0f0f0; color:var(--muted); text-align:center}
.fade-in{opacity:0; transform:translateY(10px); transition:all 0.7s ease-out}
.fade-in.visible{opacity:1; transform:none}
a{color:var(--navy)}
@media(max-width:700px){
  .header-inner{flex-direction:column; gap:12px; padding:10px}
  .nav{display:flex; gap:8px; flex-wrap:wrap}
  .hero h1{font-size:22px}
}
